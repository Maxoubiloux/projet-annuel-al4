generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Brand {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  motos     Moto[]

  @@map("brands")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  motos     Moto[]

  @@map("categories")
}

model Status {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  motos     Moto[]

  @@map("statuses")
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(100)
  email     String    @unique @db.VarChar(255)
  password  String    @db.VarChar(255)
  createdAt DateTime  @default(now()) @map("created_at")
  bookings  Booking[]

  @@map("users")
}

model Shop {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(100)
  address   String    @db.VarChar(255)
  city      String    @db.VarChar(100)
  zipCode   String    @map("zip_code") @db.VarChar(10)
  country   String    @db.VarChar(100)
  phone     String    @db.VarChar(20)
  email     String    @db.VarChar(255)
  createdAt DateTime  @default(now()) @map("created_at")
  bookings  Booking[]

  @@map("shops")
}

model Moto {
  id           String   @id @default(uuid()) @db.Uuid
  brandId      String   @map("brand_id") @db.Uuid
  model        String   @db.VarChar(100)
  serialNumber String   @unique @map("serial_number") @db.VarChar(50)
  registration String   @unique @db.VarChar(20)
  categoryId   String   @map("category_id") @db.Uuid
  statusId     String   @map("status_id") @db.Uuid
  currentKm    Int      @map("current_km")
  pricePerDay  Float    @map("price_per_day")
  description  String   @db.Text
  style        String   @db.VarChar(50)
  year         Int
  hp           Float
  torque       Float
  consumption  Float
  range        Int
  createdAt    DateTime @default(now()) @map("created_at")

  brand    Brand     @relation(fields: [brandId], references: [id])
  category Category  @relation(fields: [categoryId], references: [id])
  status   Status    @relation(fields: [statusId], references: [id])
  images   Image[]
  bookings Booking[]

  @@map("motos")
}

model Image {
  id        String   @id @default(uuid()) @db.Uuid
  motoId    String   @map("moto_id") @db.Uuid
  url       String   @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  moto Moto @relation(fields: [motoId], references: [id])

  @@map("images")
}

model Booking {
  id        String   @id @default(uuid()) @db.Uuid
  motoId    String   @map("moto_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  shopId    String   @map("shop_id") @db.Uuid
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  createdAt DateTime @default(now()) @map("created_at")

  moto Moto @relation(fields: [motoId], references: [id])
  user User @relation(fields: [userId], references: [id])
  shop Shop @relation(fields: [shopId], references: [id])

  @@map("bookings")
}
