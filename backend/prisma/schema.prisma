generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MotoStatus {
  PUBLISHED
  RESERVED
  RENTED
  MAINTENANCE
  DAMAGED
}

enum MotoCategory {
  A1
  A2
  A
  MAXI_SCOOTER
}

model Moto {
  id           String       @id @default(uuid()) @db.Uuid
  brand        String       @db.VarChar(100)
  model        String       @db.VarChar(100)
  registration String       @unique @db.VarChar(20)
  category     MotoCategory
  status       MotoStatus   @default(PUBLISHED)
  currentKm    Int          @map("current_km")
  pricePerDay  Float        @map("price_per_day")
  createdAt    DateTime     @default(now()) @map("created_at")

  @@map("motos")
}
