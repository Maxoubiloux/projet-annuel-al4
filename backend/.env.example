# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=moto_rental
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Keycloak IAM
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=moto-rental
KEYCLOAK_CLIENT_ID=moto-rental-backend
KEYCLOAK_CLIENT_SECRET=secret

# S3/GCS Storage
STORAGE_BUCKET=moto-rental-documents
STORAGE_REGION=us-east-1

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
